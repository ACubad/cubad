# ===== AI features =====
# Optional: enables the AI tutor for all visitors.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ===== Legacy Supabase project ("sprout") — rollback compatibility only =====
# Do NOT remove during the Phase 3 rollback window. The deployed app does not read these values.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ===== New Supabase project ("cubad", eu-central-1) =====
# From the Supabase dashboard: Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret. NEVER prefix with NEXT_PUBLIC_, NEVER import from a
# "use client" file — it bypasses Row Level Security entirely.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only token for /api/revalidate and scripts/upsert-unit.mjs. Generate and configure it
# locally/Vercel only; never commit a value or prefix it with NEXT_PUBLIC_.
REVALIDATE_SECRET=

# ===== Email (Resend) — consumed starting Phase 2/6 =====
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
EMAIL_FROM=

# ===== App =====
# Canonical base URL used in emails/redirects, e.g. https://cubad.vercel.app
NEXT_PUBLIC_APP_URL=
